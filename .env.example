# AGENT_API_KEY — current agent backend (today: Cursor Integrations dashboard)
# Legacy CURSOR_API_KEY is still accepted if AGENT_API_KEY is unset.
AGENT_API_KEY=

# Bearer token for the web UI / API (quote if it contains # or spaces)
ACCESS_TOKEN=

# Optional
# PORT=8787
# DEFAULT_WORKSPACE=C:/Users/you/Documents/GitHub/my-project
# DEFAULT_MODEL=auto
# WEBCLI_DATA_DIR=
# WEBCLI_STAND=0

# Whisper (local STT). Model downloads from Hugging Face; default mirror for blocked regions:
# HF_ENDPOINT=https://hf-mirror.com
# HF_ENDPOINT=https://huggingface.co
# Or set HTTP_PROXY / HTTPS_PROXY if you use a proxy instead of a mirror.
# WHISPER_MODEL=large-v3
# WHISPER_START_TIMEOUT_MS=900000
# Pre-download: download-whisper.bat
